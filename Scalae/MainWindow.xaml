<Window x:Class="Scalae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalae"
        xmlns:ScottPlot="clr-namespace:ScottPlot;assembly=ScottPlot"
        xmlns:Charting="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=DotNetProjects.DataVisualization.Toolkit"
        mc:Ignorable="d"
        Title="Scalae" Background="#480355" Height="618" Width="938">
    <Grid ClipToBounds="True" Margin="0,0,0,67">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="877*"/>
            <ColumnDefinition Width="534*"/>
        </Grid.ColumnDefinitions>
        <TabControl SelectionChanged="TabControl_SelectionChanged" Background="#9448bc" Grid.ColumnSpan="2" Margin="20,20,20,20" Padding="10,10,10,10">
            <TabItem Header="Client Info" Height="22" Margin="5,1,-9,0" VerticalAlignment="Top">
                <Grid Background="#7699d4" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width=".1*"/>
                        <ColumnDefinition Width=".9*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Named ListBox so code-behind can bind ItemsSource, I made it to where it read from the computer list might need to change where this si done for mvvm -->
                    <ListBox Grid.Column="0" Background="#63b4d1" x:Name="ListBoxMachines"
                             SelectionChanged="ListBox_SelectionChanged"
                             Margin="0,0,0,0" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Column="1" Background="#90fcf9" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="57*"/>
                            <ColumnDefinition Width="713*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="{Binding SelectedItem.Name, ElementName=ListBoxMachines}" BorderBrush="Black" Margin="5,5,5,5" IsEnabled="False" HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2">


                            <Grid Background="#7699D4" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width=".8*"/>
                                    <ColumnDefinition Width=".2*"/>
                                </Grid.ColumnDefinitions>


                                <Charting:Chart Grid.Column="0" Title="CPU Utilization" HorizontalAlignment="Left" x:Name="CpuChart" ScrollViewer.HorizontalScrollBarVisibility="Auto" Width="484">
                                    <Charting:Chart.Series>
                                        <Charting:ColumnSeries
                                            Title="Hardware %"
                                            IndependentValuePath="Key"
                                            DependentValuePath="Value"
                                            x:Name="HardwareSeries">
                                            <!-- Set the range of the Y-axis to 0-100% -->
                                            <Charting:ColumnSeries.DependentRangeAxis>
                                                <Charting:LinearAxis Minimum="0" Maximum="100" Orientation="Y" ShowGridLines="True"/>
                                            </Charting:ColumnSeries.DependentRangeAxis>
                                        </Charting:ColumnSeries>
                                    </Charting:Chart.Series>
                                </Charting:Chart>
                                <StackPanel Grid.Column="1">
                                    <Label Content="Client" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding SelectedItem.Name, ElementName=ListBoxMachines}" Height="45"/>

                                    <Label Content="CPU" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedItem.LastCpuModel, ElementName=ListBoxMachines}" Height="63" TextWrapping="Wrap"/>

                                    <Label Content="RAM" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="RAM Information" Height="46"/>

                                    <Label Content="GPU" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedItem.LastGpuModel, ElementName=ListBoxMachines}" Height="49" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>


            </TabItem>
            <TabItem Header="Graphing" Margin="5,1,-9,0">
                <Grid Background="Pink"/>

            </TabItem>
            <TabItem Header="History" Margin="5,1,-9,0">
                <Grid Background="#7699d4" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width=".1*"/>
                        <ColumnDefinition Width=".9*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" Background="#63b4d1" SelectionChanged="ListBox_SelectionChanged" Margin="0,0,0,0" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="test" FontWeight="Bold"/>
                                    <TextBlock Text="test" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Column="1" Background="#90fcf9" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width=".1*"/>
                            <ColumnDefinition Width=".9*"/>
                        </Grid.ColumnDefinitions>

                        <Viewbox Stretch="Uniform" Margin="38,0,588,342" Grid.ColumnSpan="2">
                            <Calendar Margin="57,10,0,0"/>
                        </Viewbox>

                        <ComboBox Grid.Column="1"  Margin="124,10,523,418" IsEditable="False" SelectedIndex="0" MaxWidth="300" MaxHeight="50" MinWidth="200" MinHeight="50">
                            <ComboBoxItem Content="Hours"/>
                            <ComboBoxItem Content="Hour 1"/>
                            <ComboBoxItem Content="Hour 2"/>
                            <ComboBoxItem Content="Hour 3"/>
                        </ComboBox>

                        <GroupBox Header="Selected machine" BorderBrush="Black" Margin="5,112,10,5" IsEnabled="False" HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2">
                            <!--
                            <Canvas Background="white" Margin="10,0,444,0">
                                
                                <Line X1="0" Y1="300" X2="500" Y2="300" Stroke="Black" StrokeThickness="2"/>
                                
                                <Line X1="50" Y1="0" X2="50" Y2="300" Stroke="Black" StrokeThickness="2"/>
                            </Canvas>-->

                            <Polyline Stroke="Black" StrokeThickness="2" Points="50,250 100,200 150,180 200,150 250,120 300,100 350,80 400,60 450,50"/>

                        </GroupBox>
                        <StackPanel Orientation="vertical" Margin="574,127,29,0" Grid.Column="1" >
                            <Label Content="Average" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Average info" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Max Ram" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Max Ram" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Min Ram" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Min RAM" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Max CPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Max CPU" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Min CPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Min CPU" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Max GPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Max GPU" Height="15" TextWrapping="Wrap"/>
                            
                            <Label Content="Min GPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock Text="Min GPU" Height="15" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Grid>

            </TabItem>
            <TabItem Header="Settings" Margin="5,1,-9,0">
                <Grid Background="Pink"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

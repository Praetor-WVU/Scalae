<Window x:Class="Scalae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalae"
        
        xmlns:Charting="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=DotNetProjects.DataVisualization.Toolkit"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Scalae" Background="#480355" Height="618" Width="938" MinHeight="600" MinWidth="600">
    <Grid ClipToBounds="True" Margin="0,0,0,67">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="877*"/>
            <ColumnDefinition Width="534*"/>
        </Grid.ColumnDefinitions>
        <TabControl SelectionChanged="TabControl_SelectionChanged" Background="#9448bc" Grid.ColumnSpan="2" Margin="20,20,20,20" Padding="10,10,10,10">
            <TabItem Header="Client Info" Height="22" Margin="5,1,-9,0" VerticalAlignment="Top">
                <Grid Background="#7699d4" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width=".1*"/>
                        <ColumnDefinition Width=".9*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Named ListBox so code-behind can bind ItemsSource, I made it to where it read from the computer list might need to change where this si done for mvvm -->
                    <ListBox Grid.Column="0" Background="#63b4d1" x:Name="ListBoxMachines"
                             SelectionChanged="ListBox_SelectionChanged"
                             Margin="0,0,0,0" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Column="1" Background="#90fcf9" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width=".5*"/>
                            <ColumnDefinition Width=".5*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="{Binding SelectedItem.Name, ElementName=ListBoxMachines}" BorderBrush="Black" Margin="5,5,5,5" IsEnabled="False" HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2">


                            <Grid Background="#7699D4" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.2*"/>
                                </Grid.ColumnDefinitions>


                                <Charting:Chart Grid.Column="0" Title="CPU Utilization" HorizontalAlignment="Left" x:Name="CpuChart" ScrollViewer.HorizontalScrollBarVisibility="Auto" Width="484">
                                    <Charting:Chart.Series>
                                        <Charting:ColumnSeries
                                            Title="Hardware %"
                                            IndependentValuePath="Key"
                                            DependentValuePath="Value"
                                            x:Name="HardwareSeries">
                                            <!-- Set the range of the Y-axis to 0-100% -->
                                            <Charting:ColumnSeries.DependentRangeAxis>
                                                <Charting:LinearAxis Minimum="0" Maximum="100" Orientation="Y" ShowGridLines="True"/>
                                            </Charting:ColumnSeries.DependentRangeAxis>
                                        </Charting:ColumnSeries>
                                    </Charting:Chart.Series>
                                </Charting:Chart>
                                <StackPanel Grid.Column="1">
                                    <Label Content="Client" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="Black"/>
                                    <TextBlock Text="{Binding SelectedItem.Name, ElementName=ListBoxMachines}" Height="45"/>

                                    <Label Content="CPU" FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding SelectedItem.LastCpuModel, ElementName=ListBoxMachines}" Height="63" TextWrapping="Wrap"/>

                                    <Label Content="RAM" FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding SelectedItem.LastRamModel, ElementName=ListBoxMachines}" Height="46"/>

                                    <Label Content="GPU" FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                    <TextBlock Text="{Binding SelectedItem.LastGpuModel, ElementName=ListBoxMachines}" Height="49" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>


            </TabItem>
            <TabItem Header="Graphing" Margin="5,1,-9,0">
                <Grid Background="Pink"/>

            </TabItem>
            <TabItem Header="History" Margin="5,1,-9,0" Height="21" VerticalAlignment="Top">
                <Grid Background="#7699d4" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" x:Name="ListBoxHistory" Background="#63b4d1" SelectionChanged="ListBoxHistory_SelectionChanged" Margin="0,0,0,0" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Column="1" Background="#90fcf9" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="0.4*"/>
                            <ColumnDefinition Width="0.4*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.4*"/>
                            <RowDefinition Height="0.6*"/>
                        </Grid.RowDefinitions>
 
                        <Calendar x:Name="HistoryCalendar" IsTodayHighlighted="False" SelectionMode="MultipleRange" SelectedDatesChanged="HistoryCalendar_SelectedDatesChanged">
                            <Calendar.LayoutTransform>
                                <ScaleTransform ScaleX="0.9" ScaleY="0.8"/>
                            </Calendar.LayoutTransform>
                        </Calendar>
                        
                        <Button Content="Clear Dates" Click="BtnClearDates_Click" Height="30" Width="80" Grid.Column="1"/>

                        
                        <ScottPlot:WpfPlot x:Name="WpfPlot1" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="10,0,0,0"/>

                      

                        <StackPanel Orientation="vertical" Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">

                            
                            <Label Content="Average RAM" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="AverageRamUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Max Ram" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MaxRamUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Min Ram" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MinRamUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Average CPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="AverageCpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Max CPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MaxCpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Min CPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MinCpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Average GPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="AverageGpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Max GPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MaxGpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>
                            <Label Content="Min GPU" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                            <TextBlock x:Name="MinGpuUtilization" Text="" Height="15" TextWrapping="Wrap"/>

                        </StackPanel>
                    </Grid>
                </Grid>

            </TabItem>

            <TabItem Header="Detection" Margin="5,1,-9,0">
                <Grid Background="#7699d4" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.34*"/>
                        <ColumnDefinition Width="0.33*"/>
                        <ColumnDefinition Width="0.33*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.90*"/>
                        <RowDefinition Height="0.10*"/>
                    </Grid.RowDefinitions>




                    <Grid Grid.Column="0" Margin="20,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="LBDetected" Grid.Row="0" Background="#63b4d1" SelectionChanged="ListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Scan Network" Click="BtnScanNetwork_Click" Height="30"/>
                            <Button Grid.Column="1" Content="Accept" Click="BtnAccept_Click" Height="30"/>
                            <Button Grid.Column="2" Content="Blacklist" Click="BtnBlacklist_Click" Height="30"/>
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="1" Margin="20,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.1*"/>
                            <RowDefinition Height="0.8*"/>
                            <RowDefinition Height="0.1*"/>
                        </Grid.RowDefinitions>

                        <Label Content="Whitelist"  Grid.Row="0"/>
                        <Grid Grid.Row="1" Grid.ColumnSpan="4">


                            <ListBox x:Name="LBWhitelist" Background="#63b4d1" Grid.ColumnSpan="4" Grid.Row="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" Margin="4">
                                          <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="Black"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </Grid>
                        <Grid Grid.Row="2" Grid.ColumnSpan="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="Add" Height="30" Click="AddMachine_WhiteList"/>
                                <Button Grid.Column="1" Content="Remove" Height="30" Click="RemoveMachine_WhiteList"/>
                                <CheckBox Grid.Column="2" Content="Suspend" Height="30"/>
                        </Grid>
                    </Grid>



                    <Grid Grid.Column="2" Grid.ColumnSpan="4" Margin="20,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.25*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.1*"/>
                            <RowDefinition Height="0.8*"/>
                            <RowDefinition Height="0.1*"/>
                        </Grid.RowDefinitions>
                        <Label Content="Blacklist" Grid.Row="0"/>

                        <ListBox x:Name="LBBlacklist" Background="#63b4d1" Grid.ColumnSpan="4" Grid.Row="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="4">
                                        <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="Black"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" Grid.ColumnSpan="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Add" Height="30" Click="AddMachine_BlackList"/>
                        <Button Grid.Column="1" Content="Remove" Height="30" Click="RemoveMachine_BlackList"/>

                        </Grid>
                    </Grid>


                </Grid>
            </TabItem>

            <TabItem Header="Graphing" Margin="5,1,-9,0">
                <Grid Background="#7699d4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.10*"/>
                        <ColumnDefinition Width="0.90*"/>
                    </Grid.ColumnDefinitions>


                    <Button Grid.Column="0" Content="Select" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Click="Button_Click"/>







                </Grid>
            </TabItem>

            <TabItem Header="Settings" Margin="8,1,-12,-1">
                <Grid Background="#7699d4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="103*"/>
                        <ColumnDefinition Width="189*"/>
                    </Grid.ColumnDefinitions>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>

</Window>

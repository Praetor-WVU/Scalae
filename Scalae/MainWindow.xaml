<Window x:Class="Scalae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalae"
        xmlns:ScottPlot="clr-namespace:ScottPlot;assembly=ScottPlot"
        xmlns:Charting="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=DotNetProjects.DataVisualization.Toolkit"
        mc:Ignorable="d"
        Title="Scalae" Background="#480355" Height="618" Width="938">
    <Grid ClipToBounds="True" Margin="0,0,0,67">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="877*"/>
            <ColumnDefinition Width="534*"/>
        </Grid.ColumnDefinitions>
        <TabControl SelectionChanged="TabControl_SelectionChanged" Background="#9448bc" Grid.ColumnSpan="2" Margin="0,51,0,10">
            <TabItem Header="Tab 1" Height="22" Margin="1,1,-5,0" VerticalAlignment="Top">
                <Grid Background="#7699d4" Height="387" Margin="10,0,10,0">
                    <!-- Named ListBox so code-behind can bind ItemsSource, I made it to where it read from the computer list might need to change where this si done for mvvm -->
                    <ListBox  Background="#63b4d1" x:Name="ListBoxMachines"
                             SelectionChanged="ListBox_SelectionChanged"
                             Margin="0,0,647,0" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Background="#90fcf9" Margin="185,0,0,0">

                        <GroupBox Header="{Binding SelectedItem.Name, ElementName=ListBoxMachines}" BorderBrush="Black" Margin="5,5,5,5" IsEnabled="False" HorizontalContentAlignment="Stretch">
                            <Label  Background="#7699D4" Height="366" Margin="2,0,2,0">
                                <StackPanel>
                                    <Charting:Chart Height="166" Width="266" Title="CPU Utilization" HorizontalAlignment="Left" x:Name="CpuChart" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <Charting:Chart.Series>
                                            <Charting:ColumnSeries
                                            Title="CPU %"
                                            IndependentValuePath="Key"
                                            DependentValuePath="Value"
                                            x:Name="CpuSeries">
                                            </Charting:ColumnSeries>
                                        </Charting:Chart.Series>
                                    </Charting:Chart>
                                    <!--<Label Content="Client"/>
                                    <TextBlock Content ="ClientInfo"/>-->
                                </StackPanel>
                            </Label>


                        </GroupBox>
                        <GroupBox Margin="334,10,31,23">
                            <StackPanel>
                                <Label Content="Client" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Client Information" Height="45"/>

                                <Label Content="CPU" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="CPU Information" Height="63"/>

                                <Label Content="RAM" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="RAM Information" Height="46"/>

                                <Label Content="GPU" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="GPU Information" Height="49"/>

                            </StackPanel>
                        </GroupBox>

                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Tab 2" Margin="5,1,-9,0">
                <Grid Background="Pink"/>

            </TabItem>
        </TabControl>
    </Grid>
</Window>

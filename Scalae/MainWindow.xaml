<Window x:Class="Scalae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalae"
        mc:Ignorable="d"
        Title="Scalae" Background="Pink" Height="450" Width="800">
    <Grid>
        <TabControl Height="434" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Tab 1" Height="22" Margin="-2,-2,-2,0" VerticalAlignment="Top">
                <Grid Background="Purple">
                    <ListBox d:ItemsSource="{d:SampleData ItemCount=8}" SelectionChanged="ListBox_SelectionChanged" Margin="0,0,680,0"/>
                    <Canvas Background="pink" Margin="200,34,200,34">
                        
                    </Canvas>
                </Grid>

            </TabItem>
            <TabItem Header="Tab 2">
                <Grid Background="Pink"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>

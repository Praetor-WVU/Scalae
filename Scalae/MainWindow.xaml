<Window x:Class="Scalae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalae"
        mc:Ignorable="d"
        Title="Scalae" Background="Pink" Height="450" Width="800">
    <Grid>
        <TabControl Height="434" SelectionChanged="TabControl_SelectionChanged" Background="pink">
            <TabItem Header="Tab 1" Height="22" Margin="1,1,-5,0" VerticalAlignment="Top">
                <Grid Background="Purple">
                    <!-- Named ListBox so code-behind can bind ItemsSource, I made it to where it read from the computer list might need to change where this si done for mvvm -->
                    <ListBox x:Name="ListBoxMachines"
                             SelectionChanged="ListBox_SelectionChanged"
                             Margin="0,0,680,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinWidth="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IPAddress}" FontSize="12" Foreground="LightGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Canvas Background="pink" Margin="200,34,200,34">
                    </Canvas>
                </Grid>
            </TabItem>
            <TabItem Header="Tab 2" Margin="5,1,-9,0">
                <Grid Background="Pink"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
